{
  "editable": true,
  "panels": [
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Real-time Status",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "watt", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(ac_power_watts) as value FROM (SELECT DISTINCT ON (inverter_sn) ac_power_watts FROM inverter_data WHERE $__timeFilter(update_time) ORDER BY inverter_sn, update_time DESC) as latest;"
        }
      ],
      "title": "Live AC Output",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "watt", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(mppt1_power_watts) as value FROM (SELECT DISTINCT ON (inverter_sn) mppt1_power_watts FROM inverter_data WHERE $__timeFilter(update_time) ORDER BY inverter_sn, update_time DESC) as latest;"
        }
      ],
      "title": "Live DC Input",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { 
        "defaults": { 
          "unit": "kwh", 
          "decimals": 2,
          "min": 0,
          "max": 50,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        } 
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(daily_inverter_output_kwh) as value FROM (SELECT DISTINCT ON (inverter_sn) daily_inverter_output_kwh FROM inverter_data WHERE $__timeFilter(update_time) ORDER BY inverter_sn, update_time DESC) as latest;"
        }
      ],
      "title": "Today's Yield",
      "type": "gauge"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 10,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT AVG(inverter_temperature_celsius) as value FROM (SELECT DISTINCT ON (inverter_sn) inverter_temperature_celsius FROM inverter_data WHERE $__timeFilter(update_time) ORDER BY inverter_sn, update_time DESC) as latest;"
        }
      ],
      "title": "Avg Inverter Temp",
      "type": "stat"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 11,
      "title": "Daily Peaks",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "watt", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 6 },
      "id": 12,
      "options": { 
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": [], "fields": "", "values": true },
        "textMode": "value"
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT total_ac as value, to_char(time, 'HH24:MI') as \"At Time\" FROM (SELECT update_time as time, SUM(ac_power_watts) as total_ac FROM inverter_data WHERE $__timeFilter(update_time) GROUP BY update_time) as hourly_totals ORDER BY total_ac DESC LIMIT 1"
        }
      ],
      "title": "Max AC Output (Selected Period)",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "watt", "decimals": 2 } },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 6 },
      "id": 13,
      "options": { 
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": [], "fields": "", "values": true },
        "textMode": "value"
      },
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT total_dc as value, to_char(time, 'HH24:MI') as \"At Time\" FROM (SELECT update_time as time, SUM(mppt1_power_watts) as total_dc FROM inverter_data WHERE $__timeFilter(update_time) GROUP BY update_time) as hourly_totals ORDER BY total_dc DESC LIMIT 1"
        }
      ],
      "title": "Max DC Input (Selected Period)",
      "type": "stat"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 5,
      "title": "Power Curves",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "watt", "decimals": 2 } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "id": 6,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(update_time, $__interval), SUM(mppt1_power_watts) as \"Total DC Input\", SUM(ac_power_watts) as \"Total AC Output\" FROM inverter_data WHERE $__timeFilter(update_time) GROUP BY 1 ORDER BY 1"
        }
      ],
      "title": "Generation Curve (AC vs DC)",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 7,
      "title": "Hardware Health",
      "type": "row"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 8,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT update_time as time, (ac_power_watts / NULLIF(mppt1_power_watts, 0)) * 100 as \"Efficiency\", inverter_sn FROM inverter_data WHERE $__timeFilter(update_time) ORDER BY 1"
        }
      ],
      "title": "Inverter Efficiency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 2 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 9,
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT $__timeGroupAlias(update_time, $__interval), AVG(inverter_temperature_celsius) as \"Temp\", inverter_sn FROM inverter_data WHERE $__timeFilter(update_time) GROUP BY 1, 3 ORDER BY 1"
        }
      ],
      "title": "Thermal Monitoring (by Inverter)",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "time": { "from": "now/d", "to": "now" },
  "timezone": "utc",
  "title": "SolaX - Daily Performance",
  "uid": "solax-daily"
}
