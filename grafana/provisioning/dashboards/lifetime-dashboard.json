                ]
              }
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Peak Power" },
              "properties": [
                { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient", "valueDisplay": "color" } },
