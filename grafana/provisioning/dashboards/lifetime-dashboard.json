{
  "editable": true,
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { 
        "defaults": { 
          "unit": "kwh", 
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        } 
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT SUM(max_val) as value FROM (SELECT MAX(total_inverter_output_kwh) as max_val FROM inverter_data GROUP BY inverter_sn) as total;"
        }
      ],
      "title": "Lifetime Generation",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "solax-postgres-db" },
      "fieldConfig": { 
          "defaults": { 
              "color": { "mode": "thresholds" },
